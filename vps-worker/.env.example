# --- M2A (conta de serviço) ---
# Subdomínio do tenant no M2A. Ex.: https://prefeituraxxx.m2atecnologia.com.br
M2A_BASE_URL=https://SEU-TENANT.m2atecnologia.com.br
M2A_USERNAME=usuario.servico
M2A_PASSWORD=senha-da-conta-de-servico
# Caminho do form de login (geralmente /login/).
M2A_LOGIN_PATH=/login/

# --- Auth do proxy (compartilhado com a edge function "m2a-proxy") ---
# Gere com:  openssl rand -hex 32
SHARED_SECRET=troque-isto-em-producao

# --- Servidor ---
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
# Concorrência máxima de requests simultâneos contra o M2A.
M2A_MAX_CONCURRENCY=2
