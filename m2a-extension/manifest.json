{
  "manifest_version": 3,
  "name": "M2A Integrador Automático",
  "version": "1.8.17",
  "description": "Automatiza envio de contratos, sincroniza numeração e mapeia atas/itens/contratos por processo (cascata via endpoints).",
  "permissions": ["tabs", "scripting", "activeTab", "storage", "downloads"],
  "host_permissions": [
    "http://*.m2atecnologia.com.br/*",
    "https://*.m2atecnologia.com.br/*",
    "https://*.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "M2A Integrador"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://planeja.petrvs.workers.dev/*"
      ],
      "js": ["app_bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*.m2atecnologia.com.br/*",
        "https://*.m2atecnologia.com.br/*"
      ],
      "js": ["m2a_bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "automation_engine.js",
        "engine/numeracao_scraper.js",
        "engine/processo_scraper.js"
      ],
      "matches": [
        "http://*.m2atecnologia.com.br/*",
        "https://*.m2atecnologia.com.br/*"
      ]
    }
  ]
}
